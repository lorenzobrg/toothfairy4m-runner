# Copy to .env for docker compose

RUNNER_TASK_NAME=toothfairy4m_runner.process_job
RUNNER_QUEUE={{ cookiecutter.runner_queue }}
RUNNER_WORKER_ID={{ cookiecutter.algorithm_slug }}-worker

# Use host.docker.internal when ToothFairy4M runs on host machine
RUNNER_API_BASE_URL=http://web-dev:8000
RUNNER_API_TOKEN=dev-runner-token

# Adjust to your reachable Redis broker
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# Adjust to your reachable MinIO endpoint
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_BUCKET=toothfairy4m-dev
OBJECT_STORAGE_USE_SSL=0
OBJECT_STORAGE_KEY_PREFIX=

# Map modality slug to algorithm image available to host Docker daemon
ALGORITHM_IMAGE_MAP={"{{ cookiecutter.modality_slug }}":"toothfairy4m-{{ cookiecutter.algorithm_slug }}:latest"}

RUNNER_WORKDIR_ROOT=/tmp/toothfairy4m-runner

# Optional compose overrides
RUNNER_CONCURRENCY=1
RUNNER_PREFETCH_MULTIPLIER=1
RUNNER_IMAGE=toothfairy4m-{{ cookiecutter.algorithm_slug }}:latest
RUNNER_CONTAINER_NAME=toothfairy4m-{{ cookiecutter.algorithm_slug }}-runner
